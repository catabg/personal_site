---
import BaseLayout from '../layouts/BaseLayout.astro';
import instagramFeed from '../data/instagram-feed.json';

const cvUrl = `${import.meta.env.BASE_URL}cv.pdf`;
const linkedInUrl = 'https://www.linkedin.com/in/catalina-brand-g%C3%B3mez-549922209/';
const upworkUrl = 'https://www.upwork.com/freelancers/~010e5a923c0079adb5?mp_source=share';
const githubUrl = 'https://github.com/catabg';
const profileImageUrl = `${import.meta.env.BASE_URL}profile.jpg`;
const instagramProfileUrl = 'https://www.instagram.com/box_club_col/';
const instagramPosts = instagramFeed.slice(0, 6);

const socialLinks = [
  { id: 'linkedin', label: 'LinkedIn', url: linkedInUrl },
  { id: 'upwork', label: 'Upwork', url: upworkUrl },
  { id: 'github', label: 'GitHub', url: githubUrl }
];

const valuePillars = [
  {
    title: { es: 'Investigacion primero', en: 'Research-first' },
    body: {
      es: 'Investigo contexto, detecto lo importante y organizo la informacion antes de producir.',
      en: 'I research context, spot what matters, and organize information before producing.'
    }
  },
  {
    title: { es: 'Ejecucion con estructura', en: 'Execution with structure' },
    body: {
      es: 'Convierto briefs, noticias o ideas sueltas en entregables claros, visuales y listos para publicar.',
      en: 'I turn briefs, news, or rough ideas into clear, visual, ready-to-publish deliverables.'
    }
  },
  {
    title: { es: 'Operaciones creativas', en: 'Creative operations' },
    body: {
      es: 'Combino contenido, sistemas y soporte operativo para que marcas y creators avancen mas rapido.',
      en: 'I combine content, systems, and operational support so brands and creators can move faster.'
    }
  }
];

const strengths = [
  {
    label: { es: 'Investigacion y sintesis', en: 'Research and synthesis' },
    detail: {
      es: 'Lectura de contexto, busqueda de fuentes, bases de datos y organizacion de informacion.',
      en: 'Context reading, source gathering, database work, and information organization.'
    }
  },
  {
    label: { es: 'Empaque de contenido', en: 'Content packaging' },
    detail: {
      es: 'Carruseles, captions, conceptos, newsletters y assets visuales con criterio editorial.',
      en: 'Carousels, captions, concepts, newsletters, and visual assets with editorial judgment.'
    }
  },
  {
    label: { es: 'Operaciones y resolucion de problemas', en: 'Operations and problem solving' },
    detail: {
      es: 'Seguimiento, velocidad de ejecucion, resolucion de casos y mejora de flujos de trabajo.',
      en: 'Follow-through, fast execution, case resolution, and workflow improvement.'
    }
  },
  {
    label: { es: 'Workflows asistidos con IA', en: 'AI-assisted workflows' },
    detail: {
      es: 'Uso herramientas agentic y de codigo para investigar, estructurar y acelerar entregables.',
      en: 'I use agentic and coding tools to research, structure, and accelerate deliverables.'
    }
  }
];

const services = [
  {
    title: { es: 'Investigacion y empaque de contenido', en: 'Content research and packaging' },
    body: {
      es: 'Investigo eventos, noticias, temas o referencias y los convierto en piezas listas para redes o newsletters.',
      en: 'I research events, news, topics, or references and turn them into social or newsletter-ready assets.'
    }
  },
  {
    title: { es: 'Operaciones de contenido digital', en: 'Digital content operations' },
    body: {
      es: 'Organizo calendarios, publicaciones, sistemas de informacion y procesos de apoyo para equipos pequenos.',
      en: 'I organize calendars, publishing workflows, information systems, and support processes for small teams.'
    }
  },
  {
    title: { es: 'Edicion de video y soporte para canales', en: 'Video editing and channel support' },
    body: {
      es: 'Edito videos en DaVinci Resolve, preparo thumbnails y apoyo el paquete de contenido para YouTube.',
      en: 'I edit in DaVinci Resolve, prepare thumbnails, and support the full YouTube content package.'
    }
  }
];

const projectHighlights = [
  {
    type: { es: 'Produccion para newsletters', en: 'Newsletter production' },
    title: { es: 'Carruseles de eventos y noticias locales para Scottsdale', en: 'Scottsdale event and local news carousels' },
    body: {
      es: 'Investigo la informacion, la restructuro y la convierto en paquetes de carruseles para una marca editorial local.',
      en: 'I research the information, restructure it, and turn it into carousel packages for a local editorial brand.'
    }
  },
  {
    type: { es: 'Produccion para YouTube', en: 'YouTube production' },
    title: { es: 'Edicion, thumbnails y soporte para workflows de creators', en: 'Editing, thumbnails, and support for creator workflows' },
    body: {
      es: 'Trabajo la edicion, el ritmo visual y el empaque de contenido para un canal de YouTube enfocado en tecnologia.',
      en: 'I handle editing, visual pacing, and content packaging for a technology-focused YouTube channel.'
    }
  },
  {
    type: { es: 'Investigacion academica', en: 'Academic research' },
    title: { es: 'Proyecto de investigacion publicado en el repositorio de la Universidad de Antioquia', en: 'Research project published in Universidad de Antioquia repository' },
    body: {
      es: 'Mi formacion investigativa respalda mi manera de leer contexto, justificar decisiones y estructurar informacion.',
      en: 'My research background supports how I read context, justify decisions, and structure information.'
    },
    url: 'https://bibliotecadigital.udea.edu.co/entities/publication/abe87a33-d2b6-464d-89b4-435ab92a2d61'
  }
];

const portfolioBaseUrl = `${import.meta.env.BASE_URL}portfolio/canva`;
const numberedFiles = (total) => Array.from({ length: total }, (_, index) => `${index + 1}.png`);
const prefixedFiles = (prefix, total) => Array.from({ length: total }, (_, index) => `${prefix}-${index + 1}.png`);

const canvaCampaigns = [
  { slug: 'il-bracco', title: { es: 'Il Bracco', en: 'Il Bracco' }, files: numberedFiles(4) },
  { slug: 'dia-de-muertos-scottsdale', title: { es: 'Dia de Muertos Scottsdale', en: 'Dia de Muertos Scottsdale' }, files: numberedFiles(4) },
  { slug: 'dreamy-draw-music-festival', title: { es: 'Dreamy Draw Music Festival', en: 'Dreamy Draw Music Festival' }, files: numberedFiles(4) },
  { slug: 'western-week', title: { es: 'Western Week', en: 'Western Week' }, files: numberedFiles(3) },
  { slug: 'la-la-land-kind-cafe', title: { es: 'La La Land Kind Cafe', en: 'La La Land Kind Cafe' }, files: numberedFiles(4) },
  { slug: 'cafe-monarch', title: { es: 'Cafe Monarch', en: 'Cafe Monarch' }, files: numberedFiles(3) },
  { slug: 'city-winery', title: { es: 'City Winery', en: 'City Winery' }, files: numberedFiles(4) },
  { slug: 'virgen-del-carmen', title: { es: 'Virgen del Carmen (ES/EN)', en: 'Virgen del Carmen (ES/EN)' }, files: [...prefixedFiles('es', 5), ...prefixedFiles('en', 5)] },
  { slug: 'carrusel-julio-25-28', title: { es: 'Carrusel Julio 25-28 (ES/EN)', en: 'July 25-28 Carousel (ES/EN)' }, files: [...prefixedFiles('es', 7), ...prefixedFiles('en', 7)] },
  { slug: 'estratos-medellin-espanol', title: { es: 'Estratos Medellin (Espanol)', en: 'Estratos Medellin (Spanish)' }, files: numberedFiles(6) },
  { slug: 'navidad-en-medellin-espanol', title: { es: 'Navidad en Medellin (Espanol)', en: 'Christmas in Medellin (Spanish)' }, files: numberedFiles(5) },
  { slug: 'conciertos-medellin', title: { es: 'Conciertos Medellin (ES/EN)', en: 'Medellin Concerts (ES/EN)' }, files: [...prefixedFiles('es', 7), ...prefixedFiles('en', 7)] }
].map((campaign) => ({
  ...campaign,
  slides: campaign.files.map((file, index) => ({
    src: `${portfolioBaseUrl}/${campaign.slug}/${file}`,
    index: index + 1
  }))
}));

const aiTools = [
  { name: 'Notion', label: 'Notion', icon: `${import.meta.env.BASE_URL}tool-logos/notion.svg` },
  { name: 'OpenAI', label: 'ChatGPT Codex', icon: `${import.meta.env.BASE_URL}tool-logos/openai.svg` },
  { name: 'Perplexity', label: 'Perplexity', icon: `${import.meta.env.BASE_URL}tool-logos/perplexity.svg` },
  { name: 'Git', label: 'Git / GitHub', icon: `${import.meta.env.BASE_URL}tool-logos/git.svg` }
];

const youtubeVideos = [
  {
    id: 'o5aoaCHlARo',
    url: 'https://youtu.be/o5aoaCHlARo',
    title: { es: "Don't learn n8n in 2026 - do THIS instead", en: "Don't learn n8n in 2026 - do THIS instead" }
  },
  {
    id: 'IQ1_5jPiQoE',
    url: 'https://youtu.be/IQ1_5jPiQoE?si=5EOj_sDxUbUZU3Nr',
    title: {
      es: "This Claude Code Plugin Transforms Vibe Coders Into Senior Engineers",
      en: "This Claude Code Plugin Transforms Vibe Coders Into Senior Engineers"
    }
  },
  {
    id: 'XjLUtu3ieOU',
    url: 'https://youtu.be/XjLUtu3ieOU?si=9rDXJwPY5n1uIMBl',
    title: { es: "I Canceled Claude Code. Here's Why I Came Back.", en: "I Canceled Claude Code. Here's Why I Came Back." }
  },
  {
    id: 'sns-ks-bUJM',
    url: 'https://youtu.be/sns-ks-bUJM?si=q1TMivVpcBKPvDQi',
    title: {
      es: 'How to Use Claude Code with Stata - PhD Economist Explains',
      en: 'How to Use Claude Code with Stata - PhD Economist Explains'
    }
  }
];

const experienceItems = [
  {
    role: { es: 'Freelance Digital Content Strategist and Operations Specialist', en: 'Freelance Digital Content Strategist and Operations Specialist' },
    company: { es: 'Clientes editoriales, e-commerce y creators', en: 'Editorial, e-commerce, and creator clients' },
    period: { es: '2024 - Presente', en: '2024 - Present' },
    description: {
      es: 'Research, carruseles, captions, video editing, systems de contenido y soporte operativo para proyectos digitales.',
      en: 'Research, carousels, captions, video editing, content systems, and operational support for digital projects.'
    }
  },
  {
    role: { es: 'Practicante de Comunicaciones y Cultura', en: 'Communications and Culture Intern' },
    company: { es: 'Noble Union', en: 'Noble Union' },
    period: { es: 'Enero - Julio 2025', en: 'January - July 2025' },
    description: {
      es: 'Gestion de informacion interna y apoyo en cultura organizacional.',
      en: 'Internal information management and support for organizational culture.'
    }
  },
  {
    role: { es: 'Auxiliar Administrativo', en: 'Administrative Assistant' },
    company: { es: 'Extension Cultural UdeA', en: 'UdeA Cultural Extension' },
    period: { es: 'Mayo 2023 - Enero 2024', en: 'May 2023 - January 2024' },
    description: {
      es: 'Logistica, investigacion y apoyo a comunicaciones institucionales.',
      en: 'Logistics, research, and institutional communications support.'
    }
  },
  {
    role: { es: 'Team Leader de Customer Service', en: 'Customer Service Team Leader' },
    company: { es: 'Xtendo Group', en: 'Xtendo Group' },
    period: { es: 'Abril 2021 - Febrero 2023', en: 'April 2021 - February 2023' },
    description: {
      es: 'Supervision, resolucion de casos, mejora operativa y acompanamiento de agentes para Chile y Peru.',
      en: 'Supervision, case resolution, operational improvement, and agent support for Chile and Peru.'
    }
  },
  {
    role: { es: 'Gestora pedagogica', en: 'Pedagogical Facilitator' },
    company: { es: 'Secretaria de Movilidad de Medellin', en: 'Medellin Mobility Secretariat' },
    period: { es: 'Julio - Diciembre 2019', en: 'July - December 2019' },
    description: {
      es: 'Comunicacion publica, pedagogia y trabajo en territorio.',
      en: 'Public communication, pedagogy, and field work.'
    }
  }
];
---

<BaseLayout
  title="Catalina Brand Gomez - Digital Content Strategist and Operations Specialist"
  description="Research-driven digital content strategist and operations specialist. Portfolio, content systems, editing, and AI-assisted workflows."
>
  <section class="masthead hero-shell">
    <div class="identity">
      <div class="control-row">
        <div class="lang-switch" role="group" aria-label="Selector de idioma">
          <button class="lang-btn" type="button" data-lang-set="es" aria-pressed="false">ES</button>
          <button class="lang-btn" type="button" data-lang-set="en" aria-pressed="false">EN</button>
        </div>
        <button class="theme-toggle" type="button" data-theme-toggle aria-pressed="false">
          <span aria-hidden="true">◐</span>
          <span data-theme-label>Modo noche</span>
        </button>
      </div>

      <p class="eyebrow">
        <span class="i18n es">Perfil profesional</span>
        <span class="i18n en">Professional profile</span>
      </p>
      <h1>Catalina Brand Gomez</h1>
      <p class="headline">
        <span class="i18n es">Digital Content Strategist and Operations Specialist</span>
        <span class="i18n en">Digital Content Strategist and Operations Specialist</span>
      </p>
      <p class="hero-summary">
        <span class="i18n es">
          Profesional en comunicacion con enfoque en investigacion, contenido digital, operaciones creativas y workflows asistidos con IA.
        </span>
        <span class="i18n en">
          Communication professional focused on research, digital content, creative operations, and AI-assisted workflows.
        </span>
      </p>
      <p class="location">
        <span class="i18n es">Disponible para trabajo remoto · Colaboraciones internacionales</span>
        <span class="i18n en">Available for remote work · Open to international collaborations</span>
      </p>
      <p class="hero-note">
        <span class="i18n es">Research-driven content, digital operations y produccion creativa para newsletters, marcas y creators.</span>
        <span class="i18n en">Research-driven content, digital operations, and creative production for newsletters, brands, and creators.</span>
      </p>

      <div class="social-row">
        <a class="email-link" href="mailto:catabg1410@gmail.com" aria-label="Enviar email">
          <svg viewBox="0 0 24 24" aria-hidden="true">
            <path d="M3 6.75A2.75 2.75 0 0 1 5.75 4h12.5A2.75 2.75 0 0 1 21 6.75v10.5A2.75 2.75 0 0 1 18.25 20H5.75A2.75 2.75 0 0 1 3 17.25V6.75Zm2.1-.25 6.9 5.14 6.9-5.14H5.1Zm13.4 12a1.25 1.25 0 0 0 1.25-1.25V8.38l-7.3 5.44a.75.75 0 0 1-.9 0l-7.3-5.44v8.87c0 .7.56 1.25 1.25 1.25h12.5Z" />
          </svg>
          <span>catabg1410@gmail.com</span>
        </a>

        <div class="icon-links" aria-label="Redes sociales">
          {socialLinks.map((item) => (
            <a href={item.url} target="_blank" rel="noreferrer" aria-label={item.label}>
              {item.id === 'linkedin' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M4.98 3.5C3.88 3.5 3 4.39 3 5.48S3.88 7.46 4.98 7.46c1.09 0 1.98-.88 1.98-1.98S6.07 3.5 4.98 3.5ZM3.27 8.94h3.42V20H3.27V8.94Zm5.55 0h3.28v1.57h.05c.46-.86 1.57-1.77 3.24-1.77 3.47 0 4.11 2.28 4.11 5.24V20h-3.42v-5.33c0-1.27-.02-2.91-1.77-2.91-1.77 0-2.04 1.38-2.04 2.81V20H8.82V8.94Z" />
                </svg>
              )}
              {item.id === 'upwork' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M17.5 7.1c-1.7 0-3 .8-4 2.3l-.6-.9c-.9-1.4-1.7-2.8-2.2-4.2H7.9v7.4c0 2-.8 3.1-2.3 3.1S3.3 13.7 3.3 11.8V7.3H.5v4.4c0 3.5 2 5.6 5 5.6s5-2 5-5.5v-.7l.4.6c1 1.7 2.4 3.6 5 3.6 3.2 0 5.6-2.4 5.6-5.8 0-3-2-5.4-5-5.4Zm0 8c-1.6 0-2.6-1.1-3.8-3.1l-.2-.3.1-.2c.7-1.4 1.8-2.2 3.2-2.2 1.6 0 2.7 1.2 2.7 2.9 0 1.7-1 2.9-2.6 2.9Z" />
                </svg>
              )}
              {item.id === 'github' && (
                <svg viewBox="0 0 24 24" aria-hidden="true">
                  <path d="M12 .3a12 12 0 0 0-3.79 23.39c.6.11.82-.26.82-.58v-2.03c-3.34.73-4.04-1.41-4.04-1.41-.55-1.38-1.33-1.74-1.33-1.74-1.08-.74.09-.72.09-.72 1.19.08 1.82 1.2 1.82 1.2 1.06 1.8 2.78 1.28 3.46.97.1-.76.42-1.28.76-1.57-2.66-.3-5.47-1.32-5.47-5.87 0-1.29.47-2.34 1.24-3.17-.12-.3-.54-1.52.11-3.16 0 0 1-.32 3.3 1.21a11.42 11.42 0 0 1 6 0c2.3-1.53 3.3-1.21 3.3-1.21.65 1.64.23 2.86.11 3.16.77.83 1.24 1.88 1.24 3.17 0 4.56-2.81 5.57-5.49 5.86.43.37.82 1.1.82 2.22v3.29c0 .32.21.7.82.58A12 12 0 0 0 12 .3Z" />
                </svg>
              )}
            </a>
          ))}
        </div>
      </div>

      <div class="actions">
        <a class="cta primary" href="#services">
          <span class="i18n es">Ver servicios</span>
          <span class="i18n en">View services</span>
        </a>
        <a class="cta" href={cvUrl}>
          <span class="i18n es">Descargar CV</span>
          <span class="i18n en">Download CV</span>
        </a>
      </div>
    </div>

    <div class="hero-aside">
      <div class="photo-wrap">
        <img src={profileImageUrl} alt="Foto de perfil de Catalina Brand Gomez" class="profile-photo" />
      </div>
    </div>
  </section>

  <section class="stream-section intro-grid">
    <div>
      <h2>
        <span class="i18n es">Lo que hago</span>
        <span class="i18n en">What I do</span>
      </h2>
      <p>
        <span class="i18n es">
          Ayudo a newsletters, small brands y creators a convertir informacion dispersa en contenido estructurado, workflows mas claros y entregables listos para publicar.
        </span>
        <span class="i18n en">
          I help newsletters, small brands, and creators turn scattered information into structured content, clearer workflows, and ready-to-publish deliverables.
        </span>
      </p>
    </div>
    <div class="pillars-grid">
      {valuePillars.map((pillar) => (
        <article class="pillar-card">
          <h3>
            <span class="i18n es">{pillar.title.es}</span>
            <span class="i18n en">{pillar.title.en}</span>
          </h3>
          <p>
            <span class="i18n es">{pillar.body.es}</span>
            <span class="i18n en">{pillar.body.en}</span>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section id="strengths" class="stream-section">
    <h2>
      <span class="i18n es">Fortalezas clave</span>
      <span class="i18n en">Core strengths</span>
    </h2>
    <div class="strength-list">
      {strengths.map((strength) => (
        <article class="strength-item">
          <h3>
            <span class="i18n es">{strength.label.es}</span>
            <span class="i18n en">{strength.label.en}</span>
          </h3>
          <p>
            <span class="i18n es">{strength.detail.es}</span>
            <span class="i18n en">{strength.detail.en}</span>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section id="services" class="stream-section">
    <h2>
      <span class="i18n es">Servicios</span>
      <span class="i18n en">Services</span>
    </h2>
    <div class="service-grid">
      {services.map((service) => (
        <article class="service-card">
          <h3>
            <span class="i18n es">{service.title.es}</span>
            <span class="i18n en">{service.title.en}</span>
          </h3>
          <p>
            <span class="i18n es">{service.body.es}</span>
            <span class="i18n en">{service.body.en}</span>
          </p>
        </article>
      ))}
    </div>
  </section>

  <section id="proof" class="stream-section">
    <h2>
      <span class="i18n es">Trabajo seleccionado</span>
      <span class="i18n en">Selected work</span>
    </h2>
    <div class="stream-list">
      {projectHighlights.map((project) => (
        <article>
          <p class="item-meta">
            <span class="i18n es">{project.type.es}</span>
            <span class="i18n en">{project.type.en}</span>
          </p>
          <h3>
            <span class="i18n es">{project.title.es}</span>
            <span class="i18n en">{project.title.en}</span>
          </h3>
          <p>
            <span class="i18n es">{project.body.es}</span>
            <span class="i18n en">{project.body.en}</span>
          </p>
          {project.url && (
            <a class="mini-link" href={project.url} target="_blank" rel="noreferrer">
              <span class="i18n es">Ver proyecto</span>
              <span class="i18n en">View project</span>
            </a>
          )}
        </article>
      ))}
    </div>
  </section>

  <section id="portfolio" class="stream-section">
    <h2>
      <span class="i18n es">Content portfolio</span>
      <span class="i18n en">Content portfolio</span>
    </h2>
    <p>
      <span class="i18n es">Ejemplos de carruseles investigados, estructurados y producidos para newsletters y marcas.</span>
      <span class="i18n en">Examples of carousels researched, structured, and produced for newsletters and brands.</span>
    </p>
    <div class="canva-grid">
      {canvaCampaigns.map((campaign) => (
        <article class="canva-campaign" data-carousel tabindex="0">
          <div class="canva-head">
            <h3>
              <span class="i18n es">{campaign.title.es}</span>
              <span class="i18n en">{campaign.title.en}</span>
            </h3>
            <p class="canva-counter">
              <span data-carousel-current>1</span> / {campaign.slides.length}
            </p>
          </div>
          <div class="canva-frame">
            {campaign.slides.map((slide, slideIndex) => (
              <img
                src={slide.src}
                alt={`Campaign ${campaign.title.en} slide ${slide.index}`}
                class:list={['canva-slide', slideIndex === 0 && 'is-active']}
                loading="lazy"
                width="1080"
                height="1080"
                data-carousel-slide
                aria-hidden={slideIndex === 0 ? 'false' : 'true'}
              />
            ))}
            <button type="button" class="canva-arrow prev" data-carousel-prev aria-label={`Previous slide for ${campaign.title.en}`}>
              ‹
            </button>
            <button type="button" class="canva-arrow next" data-carousel-next aria-label={`Next slide for ${campaign.title.en}`}>
              ›
            </button>
          </div>
        </article>
      ))}
    </div>
  </section>

  <section id="youtube" class="stream-section">
    <h2>YouTube</h2>
    <p>
      <span class="i18n es">Edicion en DaVinci Resolve, thumbnails y soporte de empaque para canales de tecnologia.</span>
      <span class="i18n en">DaVinci Resolve editing, thumbnails, and packaging support for technology channels.</span>
    </p>
    <div class="video-grid">
